# Copy to .env and fill in. /system-setup will help you do this.
# Everything here is OPTIONAL — you can build videos without any keys.

# Voiceover (ElevenLabs) — for AI narration
ELEVENLABS_API_KEY=

# Image generation (Replicate / Nano Banana) — for AI images
REPLICATE_API_TOKEN=

# Cloud transcription (Deepgram) — optional; local Whisper is the default
DEEPGRAM_API_KEY=
